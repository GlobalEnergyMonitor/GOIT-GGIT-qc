{ "type": "Feature", "properties": { "TerminalID": "T0385", "ProjectID": "0", "ComboID": "T038500", "Country": "China", "Region": "East Asia", "Wiki": "https://www.gem.wiki/Guangxi_LNG_Terminal", "TerminalName": "Guangxi LNG Terminal", "UnitName": "", "OtherEnglishNames": "", "Owner": "国家管网集团北海液化天然气有限责任公司 [100.00%]", "Status": "Operating", "StartYear1": "2016", "StartYear2": "", "StartYear3": "", "StopYear": "", "Import/Export": "Import", "Capacity": "3", "CapacityUnits": "mtpa", "CapacityInMtpa": "3", "Location": "Tieshan Port", "Prefecture/District": "Beihai", "State/Province": "Guangxi", "Latitude": "21.448966", "Longitude": "109.531699", "Accuracy": "exact", "Floating": "", "FID": "", "FIDYear": "", "OtherLanguageName": "中石化广西北海LNG接收站", "OtherLanguageWikiPage": "The sources in english say that this is (phase1) is a 3mpta terminal (https://www.offshore-energy.biz/sinopecs-guangxi-lng-terminal-begins-commercial-ops/). THe wiki says \"Phase I of the LNG terminal began commercial operations in April 2016, with receiving capacity of 3 mtpa\". I see no indication phase II progressed, and no citation on the 6 mpta capacity listed in the project details. I think this might be a mistaken entry, but I am not sure what the sources in chineese say.", "PowerPlantsSupplied": "" }, "geometry": { "type": "Point", "coordinates": [ 109.531699, 21.448966 ] } },
