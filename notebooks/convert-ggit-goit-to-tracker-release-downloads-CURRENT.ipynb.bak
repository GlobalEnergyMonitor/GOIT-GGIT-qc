   "source": [
    "# GEM Pipeline & Terminal Data Export\n",
    "\n",
    "Exports LNG terminals and pipelines from Google Sheets to Excel/GeoJSON/GeoPackage.\n",
    "\n",
    "**Pipeline modes:** Oil-NGL | Gas | Gas-Hydrogen | Hydrogen | Oil-and-Gas (combined)\n",
    "\n",
    "**Optional:** Filter by country list"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 48,
   "id": "0e15b4f0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ Imports loaded\n"
     ]
    }
   ],
   "source": [
    "import os\n",
    "import re\n",
    "import datetime\n",
    "import time\n",
    "from pathlib import Path\n",
    "\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "import pygsheets\n",
    "import shapely.geometry\n",
    "from shapely import from_wkt\n",
    "\n",
    "print(\"✓ Imports loaded\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "78c431d6",
   "metadata": {},
   "source": [
    "## Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
   "id": "51056feb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ Config: Oil-NGL | Filter: 1 countries\n"
     ]
    }
   ],
   "source": [
    "# Sheets\n",
    "TERMINALS_SHEET_KEY = '1fziNYGHLG1uXozfNI6MGzwyUQt6R3-30PPfug6ZqcAk'\n",
    "PIPELINES_SHEET_KEY = '1foPLE6K-uqFlaYgLPAUxzeXfDO5wOOqE7tibNHeqTek'\n",
    "\n",
    "# Pipeline type: 'Oil-NGL' | 'Gas' | 'Gas-Hydrogen' | 'Hydrogen' | 'Oil-and-Gas'\n",
    "PIPELINE_TYPE = 'Oil-NGL'\n",
    "#PIPELINE_TYPE = 'Oil-and-Gas'\n",
    "\n",
    "# Fuel simplification: None | 'Oil' | 'Oil-and-NGL' | 'Gas'\n",
    "SIMPLIFY_FUELS = 'Oil-and-NGL'\n",
    "\n",
    "# Geographic filter (None = all countries, or list of country names)\n",
    "#FILTER_COUNTRIES = None\n",
    "FILTER_COUNTRIES = ['Iran']\n",
    "# FILTER_COUNTRIES = [\n",
    "#     'Venezuela',\n",
    "#     'Colombia',\n",
    "#     'Trinidad and Tobago',\n",
    "#     'Guyana',\n",
    "#     'Suriname',\n",
    "#     'French Guiana',\n",
    "#     'Panama',\n",
    "#     'Jamaica',\n",
    "#     'Barbados',\n",
    "#     'Cuba',\n",
    "#     'Dominican Republic']\n",
    "\n",
    "# Paths\n",
    "PIPELINE_ROUTES_PATH = (\n",
    "    '/Users/baird/Google Drive/Shared drives/GEM Shared Drive/Programs/'\n",
    "    'Oil & Gas Program/Global Oil and Gas Infrastructure Trackers (GOIT, GGIT)/'\n",
    "    'GitHub routes repository/GOIT-GGIT-pipeline-routes/data/individual-routes/'\n",
    ")\n",
    "OUTPUT_DIR = 'DATA-FILES'\n",
    "Path(OUTPUT_DIR).mkdir(exist_ok=True)\n",
    "\n",
    "print(f\"✓ Config: {PIPELINE_TYPE}\" + (f\" | Filter: {len(FILTER_COUNTRIES)} countries\" if FILTER_COUNTRIES else \"\"))"
   ]
  },
  {
