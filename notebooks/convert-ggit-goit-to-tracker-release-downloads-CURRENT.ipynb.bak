   "metadata": {},
   "source": [
    "## Helper Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 50,
   "id": "e015cb22",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ Functions loaded\n"
     ]
    }
   ],
   "source": [
    "def get_config(ptype):\n",
    "    \"\"\"Pipeline configuration lookup.\"\"\"\n",
    "    configs = {\n",
    "        'Oil-NGL': {\n",
    "            'fuel_options': ['Oil',\n",
    "                             'NGL', \n",
    "                             'NGL, oil products', \n",
    "                             'LPG', \n",
    "                             'Oil, NGL',\n",
    "                             'Oil, NGL, naphtha',\n",
    "                             'Naphtha (only)', \n",
    "                             'Oil products (only)', \n",
    "                             'CO2',\n",
    "                             'Naphtha, oil products', \n",
    "                             'Condensate', \n",
    "                             'Oil, oil products',\n",
    "                             'Condensate/NGL', \n",
    "                             'Oil, condensate'],\n",
    "            'folder': 'liquid-pipelines', 'tracker': 'GOIT',\n",
    "            'sheet': 'Oil/NGL pipelines', 'dict_sheet': 'Data dictionary - Oil/NGL pipelines',\n",
    "            'copyright_sheet': 'Copyright - GOIT'\n",
    "        },\n",
    "        'Gas': {\n",
    "            'fuel_options': ['Gas', 'Gas and Hydrogen'],\n",
    "            'folder': 'gas-pipelines', 'tracker': 'GGIT',\n",
    "            'sheet': 'Gas pipelines', 'dict_sheet': 'Data dictionary - Gas pipelines',\n",
    "            'copyright_sheet': 'Copyright - GGIT'\n",
    "        },\n",
    "        'Gas-Hydrogen': {\n",
    "            'fuel_options': ['Gas', 'Hydrogen'],\n",
    "            'folder': 'gas-pipelines', 'tracker': 'GGIT',\n",
    "            'sheet': 'Gas pipelines', 'dict_sheet': 'Data dictionary - Gas pipelines',\n",
    "            'copyright_sheet': 'Copyright - GGIT'\n",
    "        },\n",
    "        'Hydrogen': {\n",
    "            'fuel_options': ['Hydrogen'],\n",
    "            'folder': 'gas-pipelines', 'tracker': 'GGIT',\n",
    "            'sheet': 'Gas pipelines', 'dict_sheet': 'Data dictionary - Gas pipelines',\n",
    "            'copyright_sheet': 'Copyright - GGIT'\n",
    "        },\n",
    "        'Oil-and-Gas': {\n",
    "            'fuel_options': ['Oil',\n",
    "                             'NGL', \n",
    "                             'NGL, oil products', \n",
    "                             'LPG', \n",
    "                             'Oil, NGL',\n",
    "                             'Oil, NGL, naphtha',\n",
    "                             'Naphtha (only)', \n",
    "                             'Oil products (only)', \n",
    "                             'CO2'\n",
    "                             'Naphtha, oil products', \n",
    "                             'Condensate', \n",
    "                             'Oil, oil products',\n",
    "                             'Condensate/NGL', \n",
    "                             'Oil, condensate'] + ['Gas', 'Gas and Hydrogen'],\n",
    "            'folder': None, 'tracker': 'GOIT-GGIT', 'sheet': None, 'dict_sheet': None, 'copyright_sheet': None\n",
    "        }\n",
    "    }\n",
    "    return configs[ptype]\n",
    "\n",
    "def fetch_pipeline_data(ss, config):\n",
    "    \"\"\"Fetch and initial filter of pipeline data from a worksheet.\"\"\"\n",
    "    df = ss.worksheet('title', config['sheet']).get_as_df(start='A3')\n",
    "    df_dict = ss.worksheet('title', config['dict_sheet']).get_as_df()\n",
    "    df_copy = ss.worksheet('title', config['copyright_sheet']).get_as_df()\n",
    "    \n",
    "    if df_copy.shape[1] > 1:\n",
    "        df_copy = pd.DataFrame(df_copy.iloc[:, 0])\n",
    "        \n",
    "    # Standard initial filters\n",
    "    mask = (\n",
    "        df['Fuel'].isin(config['fuel_options']) &\n",
    "        (df['Status'] != 'N/A') &\n",
    "        (df['PipelineName'] != '') &\n",
    "        (df['RouteAccuracy'] != '')\n",
    "    )\n",
    "    df = df[mask].copy()\n",
    "    \n",
    "    # Dataset-specific adjustments\n",
    "    if config['tracker'] == 'GGIT':\n",
    "        df.loc[df['Fuel'] == 'Gas and Hydrogen', 'Fuel'] = 'Gas'\n",
    "        \n",
    "    return df, df_dict, df_copy\n",
    "\n",
    "def filter_by_countries(df, countries, col='CountriesOrAreas'):\n",
    "    \"\"\"Filter dataframe by country list.\"\"\"\n",
    "    if not countries:\n",
    "        return df\n",
    "    mask = df[col].apply(lambda x: any(c in str(x) for c in countries) if pd.notna(x) else False)\n",
    "    return df[mask]\n",
    "\n",
    "def simplify_fuel_types(df, strategy):\n",
    "    \"\"\"Standardize fuel types based on a strategy.\"\"\"\n",
    "    if not strategy or strategy == 'None':\n",
    "        return df\n",
    "    \n",
    "    df = df.copy()\n",
    "    if strategy in ['Oil', 'Oil-and-NGL']:\n",
    "        # Priority 1: Oil (but not products)\n",
    "        oil_mask = df['Fuel'].str.contains('Oil', case=False, na=False) & \\\n",
    "                   ~df['Fuel'].str.contains('oil products', case=False, na=False)\n",
    "        \n",
    "        if strategy == 'Oil-and-NGL':\n",
    "            # Priority 2: NGL/LPG\n",
    "            ngl_mask = df['Fuel'].str.contains('NGL|LPG', case=False, na=False)\n",
    "            df.loc[ngl_mask, 'Fuel'] = 'NGL'\n",
    "            # Oil priority: overwrite if both\n",
    "            df.loc[oil_mask, 'Fuel'] = 'Oil'\n",
    "        else:\n",
    "            df.loc[oil_mask, 'Fuel'] = 'Oil'\n",
    "            \n",
    "    elif strategy == 'Gas':\n",
    "        gas_mask = df['Fuel'].str.contains('Gas', case=False, na=False)\n",
    "        df.loc[gas_mask, 'Fuel'] = 'Gas'\n",
    "        \n",
    "    return df\n",
    "\n",
    "def round_coords(wkt, decimals=6):\n",
    "    \"\"\"Round WKT coordinates.\"\"\"\n",
    "    return re.compile(r\"\\d*\\.\\d+\").sub(lambda m: f\"{float(m.group()):.{decimals}f}\", wkt)\n",
    "\n",
    "def load_geometries(df, routes_path, name, progress_every=25, slow_file_seconds=5):\n",
    "    \"\"\"Load route geometries for pipelines with progress and slow-file diagnostics.\"\"\"\n",
    "    df = df.copy()\n",
    "    pid_series = df['ProjectID'].astype('string').str.strip()\n",
    "    unique_ids = pid_series[pid_series.notna() & (pid_series != '')].unique().tolist()\n",
    "    geom_map = {}\n",
    "    failed = []\n",
    "    start = time.time()\n",
    "    \n",
    "    print(f\"Loading {name} geometries ({len(unique_ids)} unique route files for {len(df)} rows)...\")\n",
    "    \n",
    "    missing_files = [pid for pid in unique_ids if not (routes_path / f\"{pid}.geojson\").exists()]\n",
    "    if missing_files:\n",
    "        preview = ', '.join(missing_files[:10])\n",
    "        suffix = '...' if len(missing_files) > 10 else ''\n",
    "        print(f\"  Missing route files before load: {len(missing_files)} [{preview}{suffix}]\")\n",
    "    \n",
    "    for idx, pid in enumerate(unique_ids, 1):\n",
    "        route_file = routes_path / f\"{pid}.geojson\"\n",
    "        if not route_file.exists():\n",
    "            failed.append((pid, 'missing file'))\n",
    "            continue\n",
    "        \n",
    "        file_start = time.time()\n",
    "        try:\n",
    "            gdf = gpd.read_file(route_file)\n",
    "            if gdf.empty or gdf.geometry.isna().all():\n",
    "                failed.append((pid, 'empty geometry'))\n",
    "                continue\n",
    "            geom = gdf.geometry.union_all() if hasattr(gdf.geometry, 'union_all') else gdf.unary_union\n",
    "            geom_map[pid] = from_wkt(round_coords(geom.wkt))\n",
    "            file_seconds = time.time() - file_start\n",
    "            if file_seconds >= slow_file_seconds:\n",
    "                print(f\"  Slow file: {pid} took {file_seconds:.1f}s\")\n",
    "        except Exception as exc:\n",
    "            failed.append((pid, str(exc)))\n",
    "        \n",
    "        if idx % progress_every == 0 or idx == len(unique_ids):\n",
    "            elapsed = time.time() - start\n",
    "            print(\n",
    "                f\"  {idx}/{len(unique_ids)} ({idx/len(unique_ids)*100:.0f}%) | \"\n",
    "                f\"elapsed {elapsed:.1f}s | last={pid}\"\n",
    "            )\n",
    "    \n",
    "    df['geometry'] = pid_series.map(geom_map)\n",
    "    loaded = len(geom_map)\n",
    "    missing = len(failed)\n",
    "    print(f\"  ✓ Loaded: {loaded}/{len(unique_ids)} unique files | Missing/failed: {missing}\")\n",
    "    if failed:\n",
    "        sample = '; '.join([f\"{pid}: {reason}\" for pid, reason in failed[:10]])\n",
    "        suffix = ' ...' if len(failed) > 10 else ''\n",
    "        print(f\"  Failed samples: {sample}{suffix}\")\n",
    "    return df\n",
    "\n",
    "def export_files(gdf, base_name, dict_df=None, acronyms_df=None, copyright_df=None):\n",
    "    \"\"\"Export to Excel, GeoJSON, GeoPackage.\"\"\"\n",
    "    files = []\n",
    "    \n",
    "    # Excel\n",
    "    xlsx = f\"{base_name}.xlsx\"\n",
    "    with pd.ExcelWriter(xlsx, engine='openpyxl') as writer:\n",
    "        gdf.drop(columns=['geometry']).to_excel(writer, sheet_name='Data', index=False)\n",
    "        if dict_df is not None:\n",
    "            dict_df.to_excel(writer, sheet_name='Data dictionary', index=False)\n",
    "        if acronyms_df is not None:\n",
    "            acronyms_df.to_excel(writer, sheet_name='Acronyms', index=False)\n",
    "        if copyright_df is not None:\n",
    "            copyright_df.to_excel(writer, sheet_name='Copyright', index=False)\n",
    "    files.append(xlsx)\n",
    "    \n",
    "    # GeoJSON & GeoPackage\n",
    "    gjson = f\"{base_name}.geojson\"\n",
    "    gpkg = f\"{base_name}.gpkg\"\n",
    "    gdf.to_file(gjson, driver='GeoJSON')\n",
    "    gdf.to_file(gpkg, driver='GPKG')\n",
    "    files.extend([gjson, gpkg])\n",
    "    \n",
    "    print(f\"\\n✓ Exported: {', '.join([f.split('/')[-1] for f in files])}\")\n",
    "    return files\n",
    "\n",
    "print(\"✓ Functions loaded\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "dcfbef6d",
   "metadata": {},
   "source": [
    "---\n",
    "## Part 1: Terminals"
   ]
  },
  {
   "cell_type": "raw",
   "id": "21693c92",
   "metadata": {},
   "source": [
    "# Load from Google Sheets\n",
    "gc = pygsheets.authorize(service_account_env_var='GDRIVE_API_CREDENTIALS')\n",
    "ss = gc.open_by_key(TERMINALS_SHEET_KEY)\n",
    "\n",
    "terms_df = ss.worksheet('title', 'LNG export & import terminals').get_as_df(start='A3')\n",
    "terms_dict = ss.worksheet('title', 'Data dictionary - Terminals').get_as_df()\n",
    "terms_acro = ss.worksheet('title', 'Acronyms').get_as_df()\n",
    "terms_copy = ss.worksheet('title', 'Copyright - GGIT').get_as_df()\n",
    "if terms_copy.shape[1] > 1:\n",
    "    terms_copy = pd.DataFrame(terms_copy.iloc[:, 0])\n",
    "\n",
    "# Filter\n",
    "orig_count = len(terms_df)\n",
    "terms_df = terms_df[\n",
    "    (terms_df['TerminalType'] != 'Oil export terminal') &\n",
    "    (terms_df['TerminalName'] != '') &\n",
    "    (terms_df['Status'] != 'N/A')\n",
    "]\n",
    "\n",
    "# Select columns for export\n",
    "cols_to_export = terms_dict[\n",
    "    (terms_dict['IncludeWithDataRelease'] == 'Yes') &\n",
    "    (terms_dict['DataReleaseColumnOrder'].notna())\n",
    "].sort_values('DataReleaseColumnOrder')['VariableName'].tolist()\n",
    "\n",
    "terms_dict_export = terms_dict[\n",
    "    terms_dict['VariableName'].isin(cols_to_export)\n",
    "][['VariableName', 'Definition']]\n",
    "\n",
    "# Create geometries\n",
    "terms_df['geometry'] = terms_df.apply(\n",
    "    lambda r: shapely.geometry.Point(r['Longitude'], r['Latitude']) \n",
    "    if r['Longitude'] not in ['Unknown', 'TBD', ''] and r['Latitude'] not in ['Unknown', 'TBD', ''] \n",
    "    else shapely.geometry.Point(),\n",
    "    axis=1\n",
    ")\n",
    "\n",
    "terms_gdf = gpd.GeoDataFrame(terms_df[cols_to_export], geometry=terms_df['geometry'], crs='EPSG:4326')\n",
    "\n",
    "print(f\"✓ Terminals: {orig_count} → {len(terms_gdf)} (after filtering)\")\n",
    "\n",
    "# Export\n",
    "today = datetime.date.today()\n",
    "term_files = export_files(\n",
    "    terms_gdf,\n",
    "    f\"{OUTPUT_DIR}/GEM-GGIT-LNG-Terminals-{today}\",\n",
    "    terms_dict_export, terms_acro, terms_copy\n",
    ")"
   ]
  },
