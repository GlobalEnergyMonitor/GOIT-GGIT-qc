     "text": [
      "\n",
      "✓ Exported: GEM-GOIT-Oil-NGL-Pipelines-Iran-2026-03-20.xlsx, GEM-GOIT-Oil-NGL-Pipelines-Iran-2026-03-20.geojson, GEM-GOIT-Oil-NGL-Pipelines-Iran-2026-03-20.gpkg\n"
     ]
    }
   ],
   "source": [
    "# Export pipelines\n",
    "today = datetime.date.today()\n",
    "base_name = f\"{OUTPUT_DIR}/GEM-{config['tracker']}-{PIPELINE_TYPE}-Pipelines\"\n",
    "\n",
    "# Add fuel simplification suffix\n",
    "if SIMPLIFY_FUELS in ['Oil', 'Oil-and-NGL', 'Gas']:\n",
    "    fuel_lang_map = {\n",
    "        'Oil': 'simplified-oil',\n",
    "        'Oil-and-NGL': 'simplified-oil-ngl',\n",
    "        'Gas': 'simplified-gas'\n",
    "    }\n",
    "    base_name += f\"-{fuel_lang_map[SIMPLIFY_FUELS]}\"\n",
    "\n",
    "# Add country suffix if filtering\n",
    "if FILTER_COUNTRIES:\n",
    "    country_suffix = '-'.join([c.replace(' ', '') for c in FILTER_COUNTRIES])\n",
    "    base_name += f\"-{country_suffix}\"\n",
    "\n",
    "base_name += f\"-{today}\"\n",
    "\n",
    "pipe_files = export_files(\n",
    "    pipes_gdf_export,\n",
    "    base_name,\n",
    "    pipes_dict_export, pipes_acro, pipes_copy\n",
    ")"
   ]
  },
